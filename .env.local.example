# ── Shopify Storefront API ───────────────────────────────────────────────────
# 1. Ve a tu Shopify Partner Dashboard → tu tienda → Apps → Desarrollar apps
# 2. Crea una app privada y activa la Storefront API
# 3. Copia el token de acceso público aquí
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Shopify Admin API (para webhooks y revalidación) ─────────────────────────
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_WEBHOOK_SECRET=tu_webhook_secret_aqui

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Stripe ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ── Meta Ads ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=xxxxxxxxxxxxxxxx
META_CONVERSIONS_API_TOKEN=EAAxxxxxxxx...

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://nexum.co

// Nexum MaaS — Schema de base de datos
// Stack: PostgreSQL + Prisma ORM
//
// Para aplicar:
//   npx prisma migrate dev --name init
// Para generar el cliente:
//   npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Usuarios (clientes) ───────────────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  phone       String    @unique
  name        String?
  email       String?   @unique
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isActive    Boolean   @default(true)

  // Token FCM del dispositivo para notificaciones push (null = sin registrar).
  fcmToken    String?

  // Trusted contact for the SOS / share-trip safety features.
  trustedContactName  String?
  trustedContactPhone String?

  // Programa de referidos: código propio para compartir y quién lo refirió.
  referralCode  String? @unique
  referredById  String?
  referredBy    User?   @relation("UserReferrals", fields: [referredById], references: [id])
  referrals     User[]  @relation("UserReferrals")

  addresses         Address[]
  orders            Order[]
  trips             Trip[]            @relation("TripPassenger")
  ratings           Rating[]          @relation("RatingAuthor")
  errands           Errand[]
  intercityBookings IntercityBooking[]
  seatBookings      SeatBooking[]
  emergencyEvents   EmergencyEvent[]
  promoRedemptions  PromoRedemption[]

  @@map("users")
}

// ── Promociones (cupones y referidos) ─────────────────────────────────────────

enum PromoType {
  PERCENT
  FIXED
}

enum PromoScope {
  ALL
  TRIPS
  ORDERS
}

model PromoCode {
  id             String      @id @default(cuid())
  code           String      @unique
  description    String?
  type           PromoType
  /// PERCENT: 1–100; FIXED: monto en COP.
  value          Float
  scope          PromoScope  @default(ALL)
  minAmount      Float       @default(0)
  /// Tope del descuento en COP para cupones PERCENT (null = sin tope).
  maxDiscount    Float?
  /// null = sin límite global de canjes.
  maxRedemptions Int?
  perUserLimit   Int         @default(1)
  expiresAt      DateTime?
  active         Boolean     @default(true)
  /// Teléfono del admin que lo creó, o "referral" para los generados por referidos.
  createdBy      String?
  /// Si es un cupón personal, solo este usuario puede canjearlo.
  ownerUserId    String?
  createdAt      DateTime    @default(now())

  redemptions PromoRedemption[]

  @@map("promo_codes")
}

model PromoRedemption {
  id           String   @id @default(cuid())
  promoCodeId  String
  userId       String
  /// 'trip' | 'order'
  context      String
  amountBefore Float
  discount     Float
  createdAt    DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([promoCodeId])
  @@index([userId])
  @@map("promo_redemptions")
}

// ── OTP Sessions ──────────────────────────────────────────────────────────────

model OtpSession {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id])
  // Sin relación a User por `phone`: el OTP es para login/registro y el número
  // puede no existir aún en `users`. La FK otp_sessions_phone_fkey rompía el
  // envío de OTP para cualquier teléfono no registrado.

  @@index([phone])
  @@map("otp_sessions")
}

// ── Conductores ───────────────────────────────────────────────────────────────

model Driver {
  id                String       @id @default(cuid())
  phone             String       @unique
  name              String
  email             String?      @unique
  avatarUrl         String?
  documentType      String?
  documentNumber    String?      @unique
  licenseNumber     String?      @unique
  status            DriverStatus @default(OFFLINE)
  isVerified        Boolean      @default(false)
  // Disponibilidad para recibir solicitudes de viajes intermunicipales.
  intercityEnabled  Boolean      @default(false)
  // Token FCM del dispositivo para notificaciones push (null = sin registrar).
  fcmToken          String?
  rating            Float        @default(5.0)
  totalTrips        Int          @default(0)
  bio               String?
  bankName          String?
  bankAccountType   String?
  bankAccountNumber String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Trusted contact for the SOS / share-trip safety features.
  trustedContactName  String?
  trustedContactPhone String?

  // Última posición conocida
  lastLat       Float?
  lastLng       Float?
  lastSeenAt    DateTime?

  // Posición geográfica para matching por cercanía (PostGIS).
  // Prisma no soporta tipos PostGIS de forma nativa: la columna se declara como
  // Unsupported para que el cliente la conozca pero NO la gestione. Se ESCRIBE y
  // se CONSULTA exclusivamente vía SQL raw (ST_MakePoint / ST_DWithin / ST_Distance)
  // desde matching.service.ts. El índice GIST y la columna se crean en la
  // migración manual `add_postgis`.
  geo               Unsupported("geography(Point, 4326)")?

  vehicles      Vehicle[]
  trips         Trip[]
  otpSessions   OtpSession[]
  earnings      DriverEarning[]
  documents     DriverDocument[]
  emergencyEvents EmergencyEvent[]
  payouts         Payout[]

  @@index([status])
  @@map("drivers")
}

enum DriverStatus {
  OFFLINE
  ONLINE
  ON_TRIP
}

model DriverDocument {
  id              String         @id @default(cuid())
  driverId        String
  type            DocumentType
  fileUrl         String
  status          DocumentStatus @default(PENDING)
  expiresAt       String?
  rejectionReason String?
  reviewedBy      String?
  uploadedAt      DateTime       @default(now())
  reviewedAt      DateTime?

  driver          Driver         @relation(fields: [driverId], references: [id])

  @@unique([driverId, type])
  @@index([driverId])
  @@index([status])
  @@map("driver_documents")
}

enum DocumentType {
  CEDULA
  LICENSE
  SOAT
  PROPERTY_CARD
  PROFILE_PHOTO
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Vehicle {
  id           String      @id @default(cuid())
  driverId     String
  type         VehicleType
  brand        String
  model        String
  year         Int
  plate        String      @unique
  color        String
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())

  driver       Driver      @relation(fields: [driverId], references: [id])
  trips        Trip[]

  @@map("vehicles")
}

enum VehicleType {
  PARTICULAR
  TAXI
  MOTO
}

// ── Negocios aliados ──────────────────────────────────────────────────────────

model Business {
  id           String           @id @default(cuid())
  name         String
  ownerName    String?
  category     BusinessCategory
  address      String
  lat          Float?
  lng          Float?
  phone        String?
  whatsapp     String?
  rating       Float            @default(5.0)
  etaMinutes   Int              @default(30)
  deliveryFee  Float            @default(2500)
  isOpen       Boolean          @default(true)
  token        String           @unique @default(cuid())
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  products     Product[]
  orders       Order[]

  @@index([category])
  @@map("businesses")
}

enum BusinessCategory {
  RESTAURANT
  SUPERMARKET
  PHARMACY
  OTHER
}

model Product {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  description  String?
  price        Float
  category     String   @default("General")
  imageUrl     String?
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())

  business     Business    @relation(fields: [businessId], references: [id])
  orderLines   OrderLine[]

  @@index([businessId])
  @@map("products")
}

// ── Pedidos de domicilio ──────────────────────────────────────────────────────

model Order {
  id               String      @id @default(cuid())
  orderRef         String      @unique
  userId           String?
  businessId       String
  driverId         String?
  status           OrderStatus @default(CONFIRMED)
  deliveryAddress  String
  deliveryLat      Float?
  deliveryLng      Float?
  subtotal         Float
  deliveryFee      Float
  total            Float
  etaMinutes       Int?
  pickupPhotoUrl   String?
  deliveryPhotoUrl String?
  hasSignature     Boolean     @default(false)
  customerName     String?
  driverName       String?
  driverPhone      String?
  tipAmount        Float       @default(0)
  tipPaid          Boolean     @default(false)
  rating           Int?
  ratingComment    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  pickedUpAt       DateTime?
  deliveredAt      DateTime?

  user             User?       @relation(fields: [userId], references: [id])
  business         Business    @relation(fields: [businessId], references: [id])
  lines            OrderLine[]

  @@index([userId])
  @@index([driverId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  CONFIRMED
  DRIVER_TO_PICKUP
  AT_PICKUP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model OrderLine {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  subtotal    Float

  order       Order   @relation(fields: [orderId], references: [id])
  product     Product @relation(fields: [productId], references: [id])

  @@map("order_lines")
}

// ── Viajes de movilidad ───────────────────────────────────────────────────────

model Trip {
  id                 String          @id @default(cuid())
  requestRef         String          @unique
  passengerId        String?
  driverId           String?
  vehicleId          String?
  serviceType        TransportType
  status             TripStatus      @default(SEARCHING)
  originAddress      String
  originLat          Float
  originLng          Float
  destAddress        String
  destLat            Float
  destLng            Float
  estimatedFare      Float
  surgeMultiplier    Float           @default(1.0)
  finalFare          Float?
  distanceKm         Float?
  etaMinutes         Int?
  cancelReason       String?
  pickupPhotoUrl     String?
  deliveryPhotoUrl   String?
  recipientName      String?
  recipientPhone     String?
  packageDescription String?
  passengerName      String?
  passengerRating    Float?
  netEarning         Float?
  commission         Float?
  tipAmount          Float           @default(0)
  tipPaid            Boolean         @default(false)
  rating             Int?
  ratingComment      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  acceptedAt         DateTime?
  startedAt          DateTime?
  arrivedAt          DateTime?
  completedAt        DateTime?

  passenger          User?           @relation("TripPassenger", fields: [passengerId], references: [id])
  driver             Driver?         @relation(fields: [driverId], references: [id])
  vehicle            Vehicle?        @relation(fields: [vehicleId], references: [id])
  ratings            Rating[]

  @@index([passengerId])
  @@index([driverId])
  @@index([status])
  @@map("trips")
}

enum TransportType {
  TAXI
  MOTO
  PARTICULAR
  ENVIOS
  MANDADO
}

enum WorkMode {
  PASAJERO
  PEDIDO
  PAQUETE
  MANDADO
}

enum TripStatus {
  SEARCHING
  ACCEPTED
  ARRIVING
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Ganancias del conductor ───────────────────────────────────────────────────

model DriverEarning {
  id          String   @id @default(cuid())
  driverId    String
  date        DateTime @db.Date
  grossFare   Float
  commission  Float
  netEarning  Float
  tripCount   Int
  createdAt   DateTime @default(now())

  driver      Driver   @relation(fields: [driverId], references: [id])

  @@unique([driverId, date])
  @@index([driverId])
  @@map("driver_earnings")
}

// ── Retiros (payouts) del conductor ───────────────────────────────────────────
//
// El conductor acumula ganancias netas en driver_earnings. Cuando solicita un
// retiro se crea un Payout en estado REQUESTED contra su saldo disponible
// (neto acumulado − retiros ya solicitados/procesando/pagados). La operación lo
// procesa desde el panel /admin y marca PAID con la referencia de la
// transferencia. La dispersión bancaria automática (Nequi/Daviplata/ACH) es un
// paso posterior; hoy el saldo y el ciclo de vida del retiro son reales.
model Payout {
  id          String       @id @default(cuid())
  driverId    String
  amount      Float
  status      PayoutStatus @default(REQUESTED)
  /// Canal de pago: 'bank' | 'nequi' | 'daviplata'.
  method      String?
  /// Snapshot del destino (banco/cuenta o teléfono) al momento de solicitar.
  accountInfo String?
  notes       String?
  /// Referencia de la transferencia, registrada por la operación al pagar.
  reference   String?
  /// Teléfono del admin que procesó el retiro.
  processedBy String?
  requestedAt DateTime     @default(now())
  processedAt DateTime?

  driver      Driver       @relation(fields: [driverId], references: [id])

  @@index([driverId])
  @@index([status])
  @@map("payouts")
}

enum PayoutStatus {
  REQUESTED
  PROCESSING
  PAID
  REJECTED
}

// ── Direcciones guardadas del usuario ─────────────────────────────────────────

model Address {
  id          String  @id @default(cuid())
  userId      String
  alias       String
  fullAddress String
  lat         Float?
  lng         Float?
  isDefault   Boolean @default(false)

  user        User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("addresses")
}

// ── Mandados ──────────────────────────────────────────────────────────────────

model Errand {
  id               String        @id @default(cuid())
  requestRef       String        @unique
  userId           String
  driverId         String?
  category         ErrandCategory
  description      String
  pickupAddress    String
  dropoffAddress   String
  serviceFee       Float         @default(6000)
  purchaseBudget   Float?
  actualCost       Float?
  notes            String?
  status           ErrandStatus  @default(SEARCHING)
  proofPhotoUrl    String?
  deliveryPhotoUrl String?
  hasSignature     Boolean       @default(false)
  driverName       String?
  driverPhone      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  acceptedAt       DateTime?
  deliveredAt      DateTime?

  user             User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([driverId])
  @@index([status])
  @@map("errands")
}

enum ErrandCategory {
  PHARMACY
  GROCERIES
  DOCUMENTS
  PAYMENTS
  FOOD
  SHOPPING
  OTHER
}

enum ErrandStatus {
  SEARCHING
  ACCEPTED
  SHOPPING
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

// ── Viajes Intermunicipales ────────────────────────────────────────────────────

model IntercityBooking {
  id             String          @id @default(cuid())
  requestRef     String          @unique
  userId         String
  driverId       String?
  origin         IntercityCity
  destination    IntercityCity
  departureTime  DateTime
  seats          IntercitySeats
  offeredFare    Float
  counterFare    Float?
  finalFare      Float?
  status         IntercityStatus @default(SEARCHING)
  pickupAddress  String?
  dropoffAddress String?
  notes          String?
  driverName     String?
  driverPhone    String?
  driverVehicle  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  confirmedAt    DateTime?
  completedAt    DateTime?
  rating         Int?
  ratingComment  String?

  user           User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("intercity_bookings")
}

enum IntercityCity {
  PAMPLONA
  CUCUTA
  BUCARAMANGA
  CHITAGA
  MALAGA
  OCANA
  BOGOTA
}

enum IntercitySeats {
  ONE
  TWO
  THREE
  FLEET
}

enum IntercityStatus {
  SEARCHING
  DRIVER_FOUND
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Viajes compartidos (Modelo A) ─────────────────────────────────────────────

model PooledTrip {
  id                 String           @id @default(cuid())
  tripRef            String           @unique
  driverId           String
  driverName         String
  driverPhone        String
  vehicleDescription String
  origin             IntercityCity
  destination        IntercityCity
  departureTime      DateTime
  totalSeats         Int
  farePerSeat        Float
  maxFarePerSeat     Float
  allowFleet         Boolean          @default(false)
  status             PooledTripStatus @default(OPEN)
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  bookings           SeatBooking[]

  @@index([driverId])
  @@index([status])
  @@index([origin, destination])
  @@map("pooled_trips")
}

model SeatBooking {
  id             String            @id @default(cuid())
  tripId         String
  userId         String
  passengerName  String
  passengerPhone String
  seatsBooked    Int
  pickupAddress  String?
  notes          String?
  status         SeatBookingStatus @default(CONFIRMED)
  bookedAt       DateTime          @default(now())

  trip          PooledTrip        @relation(fields: [tripId], references: [id])
  user          User              @relation(fields: [userId], references: [id])

  @@index([tripId])
  @@index([userId])
  @@map("seat_bookings")
}

enum PooledTripStatus {
  OPEN
  FULL
  DEPARTED
  COMPLETED
  CANCELLED
}

enum SeatBookingStatus {
  CONFIRMED
  CANCELLED
}

// ── Calificaciones ────────────────────────────────────────────────────────────

model Rating {
  id        String   @id @default(cuid())
  authorId  String
  tripId    String?
  stars     Int
  comment   String?
  createdAt DateTime @default(now())

  author    User     @relation("RatingAuthor", fields: [authorId], references: [id])
  trip      Trip?    @relation(fields: [tripId], references: [id])

  @@map("ratings")
}

// ── Pagos (Wompi) ─────────────────────────────────────────────────────────────

model Payment {
  id            String   @id @default(cuid())
  referenceCode String   @unique
  amount        Float
  currency      String   @default("COP")
  description   String
  clientId      String
  orderId       String?
  tripId        String?
  status        String   @default("pending")
  paymentUrl    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clientId])
  @@map("payments")
}

// ── Eventos de emergencia (SOS / compartir viaje) ─────────────────────────────

model EmergencyEvent {
  id        String        @id @default(cuid())
  userId    String?
  driverId  String?
  tripId    String?
  lat       Float
  lng       Float
  type      EmergencyType @default(PANIC)
  createdAt DateTime      @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  driver    Driver?  @relation(fields: [driverId], references: [id])

  @@index([userId])
  @@index([driverId])
  @@index([tripId])
  @@map("emergency_events")
}

enum EmergencyType {
  PANIC // botón de pánico pulsado
  SHARE // viaje compartido con contacto de confianza
}

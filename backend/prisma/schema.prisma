// Nexum MaaS — Schema de base de datos
// Stack: PostgreSQL + Prisma ORM
//
// Para aplicar:
//   npx prisma migrate dev --name init
// Para generar el cliente:
//   npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Usuarios (clientes) ───────────────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  phone       String    @unique
  name        String?
  email       String?   @unique
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isActive    Boolean   @default(true)

  // Verificación de identidad del pasajero (anti-fraude/anti-robo). Mismo modelo
  // env-gated que el KYC del conductor. El conductor ve "cliente verificado".
  kycStatus         KycStatus @default(PENDING)
  kycProvider       String?
  kycReference      String?
  kycCheckedAt      DateTime?
  selfieUrl         String?

  // Token FCM del dispositivo para notificaciones push (null = sin registrar).
  fcmToken    String?

  // Trusted contact for the SOS / share-trip safety features.
  trustedContactName  String?
  trustedContactPhone String?

  // Programa de referidos: código propio para compartir y quién lo refirió.
  referralCode  String? @unique
  referredById  String?
  referredBy    User?   @relation("UserReferrals", fields: [referredById], references: [id])
  referrals     User[]  @relation("UserReferrals")

  addresses         Address[]
  orders            Order[]
  trips             Trip[]            @relation("TripPassenger")
  ratings           Rating[]          @relation("RatingAuthor")
  errands           Errand[]
  intercityBookings IntercityBooking[]
  seatBookings      SeatBooking[]
  emergencyEvents   EmergencyEvent[]
  promoRedemptions  PromoRedemption[]

  @@map("users")
}

// ── Promociones (cupones y referidos) ─────────────────────────────────────────

enum PromoType {
  PERCENT
  FIXED
}

enum PromoScope {
  ALL
  TRIPS
  ORDERS
}

model PromoCode {
  id             String      @id @default(cuid())
  code           String      @unique
  description    String?
  type           PromoType
  /// PERCENT: 1–100; FIXED: monto en COP.
  value          Float
  scope          PromoScope  @default(ALL)
  minAmount      Float       @default(0)
  /// Tope del descuento en COP para cupones PERCENT (null = sin tope).
  maxDiscount    Float?
  /// null = sin límite global de canjes.
  maxRedemptions Int?
  perUserLimit   Int         @default(1)
  expiresAt      DateTime?
  active         Boolean     @default(true)
  /// Teléfono del admin que lo creó, o "referral" para los generados por referidos.
  createdBy      String?
  /// Si es un cupón personal, solo este usuario puede canjearlo.
  ownerUserId    String?
  createdAt      DateTime    @default(now())

  redemptions PromoRedemption[]

  @@map("promo_codes")
}

model PromoRedemption {
  id           String   @id @default(cuid())
  promoCodeId  String
  userId       String
  /// 'trip' | 'order'
  context      String
  amountBefore Float
  discount     Float
  createdAt    DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([promoCodeId])
  @@index([userId])
  @@map("promo_redemptions")
}

// ── OTP Sessions ──────────────────────────────────────────────────────────────

model OtpSession {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id])
  // Sin relación a User por `phone`: el OTP es para login/registro y el número
  // puede no existir aún en `users`. La FK otp_sessions_phone_fkey rompía el
  // envío de OTP para cualquier teléfono no registrado.

  @@index([phone])
  @@map("otp_sessions")
}

// ── Conductores ───────────────────────────────────────────────────────────────

model Driver {
  id                String       @id @default(cuid())
  phone             String       @unique
  name              String
  email             String?      @unique
  avatarUrl         String?
  documentType      String?
  documentNumber    String?      @unique
  licenseNumber     String?      @unique
  status            DriverStatus @default(OFFLINE)
  isVerified        Boolean      @default(false)
  // ── KYC / verificación de identidad ──────────────────────────────────────
  // isVerified = documentos aprobados; kycStatus = identidad validada (cédula/
  // licencia contra registros + selfie/liveness). Un conductor está "habilitado
  // para conducir" solo si AMBOS pasan (gating activable con KYC_ENFORCE).
  kycStatus         KycStatus    @default(PENDING)
  kycProvider       String?      // 'manual' | 'truora' | ... (quién validó)
  kycReference      String?      // id de la verificación del proveedor
  kycCheckedAt      DateTime?
  selfieUrl         String?      // foto selfie para comparación/liveness
  // Antifraude: contador de eventos GPS sospechosos (saltos/velocidad imposible).
  fraudFlags        Int          @default(0)
  // Disponibilidad para recibir solicitudes de viajes intermunicipales.
  intercityEnabled  Boolean      @default(false)
  // Preferencias de servicio: qué tipos de solicitud recibe el conductor.
  // El matching las respeta al elegir candidatos (default: todo activo).
  acceptsTrips      Boolean      @default(true)
  acceptsErrands    Boolean      @default(true)
  acceptsOrders     Boolean      @default(true)
  // Token FCM del dispositivo para notificaciones push (null = sin registrar).
  fcmToken          String?
  rating            Float        @default(5.0)
  totalTrips        Int          @default(0)
  bio               String?
  bankName          String?
  bankAccountType   String?
  bankAccountNumber String?
  // Afiliación a una empresa de transporte (null = conductor independiente).
  operatorId        String?
  employmentType    EmploymentType?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // Trusted contact for the SOS / share-trip safety features.
  trustedContactName  String?
  trustedContactPhone String?

  // Última posición conocida
  lastLat       Float?
  lastLng       Float?
  lastSeenAt    DateTime?

  // Posición geográfica para matching por cercanía (PostGIS).
  // Prisma no soporta tipos PostGIS de forma nativa: la columna se declara como
  // Unsupported para que el cliente la conozca pero NO la gestione. Se ESCRIBE y
  // se CONSULTA exclusivamente vía SQL raw (ST_MakePoint / ST_DWithin / ST_Distance)
  // desde matching.service.ts. El índice GIST y la columna se crean en la
  // migración manual `add_postgis`.
  geo               Unsupported("geography(Point, 4326)")?

  vehicles      Vehicle[]
  trips         Trip[]
  otpSessions   OtpSession[]
  earnings      DriverEarning[]
  documents     DriverDocument[]
  emergencyEvents EmergencyEvent[]
  payouts         Payout[]
  operator         Operator?        @relation(fields: [operatorId], references: [id])
  fleetAssignments FleetAssignment[]

  @@index([status])
  @@index([operatorId])
  @@map("drivers")
}

enum DriverStatus {
  OFFLINE
  ONLINE
  ON_TRIP
}

model DriverDocument {
  id              String         @id @default(cuid())
  driverId        String
  type            DocumentType
  fileUrl         String
  status          DocumentStatus @default(PENDING)
  expiresAt       String?
  rejectionReason String?
  reviewedBy      String?
  uploadedAt      DateTime       @default(now())
  reviewedAt      DateTime?

  driver          Driver         @relation(fields: [driverId], references: [id])

  @@unique([driverId, type])
  @@index([driverId])
  @@index([status])
  @@map("driver_documents")
}

enum DocumentType {
  CEDULA
  LICENSE
  SOAT
  PROPERTY_CARD
  PROFILE_PHOTO
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycStatus {
  PENDING      // aún no envía verificación de identidad
  IN_REVIEW    // enviada; en revisión (proveedor o admin manual)
  VERIFIED     // identidad confirmada
  REJECTED     // no pasó la verificación
}

model Vehicle {
  id           String      @id @default(cuid())
  driverId     String
  type         VehicleType
  brand        String
  model        String
  year         Int
  plate        String      @unique
  color        String
  isActive     Boolean     @default(true)
  // Flota de empresa (null = vehículo de conductor independiente).
  operatorId      String?
  operationCardNo String?   // tarjeta de operación (taxi/intermunicipal)
  capacity        Int?      // # de pasajeros
  capacityKg      Int?      // capacidad de carga en kg (turbo/camión/mula)
  internalCode    String?   // "móvil 042" interno de la empresa
  // ── Documentos y cumplimiento ────────────────────────────────────────────
  photoUrl            String?   // foto del vehículo
  soatExpiry          DateTime? // vencimiento del SOAT
  rtmExpiry           DateTime? // vencimiento de la revisión técnico-mecánica
  operationCardExpiry DateTime? // vencimiento de la tarjeta de operación
  createdAt    DateTime    @default(now())

  driver       Driver      @relation(fields: [driverId], references: [id])
  trips        Trip[]
  operator         Operator?         @relation(fields: [operatorId], references: [id])
  fleetAssignments FleetAssignment[]

  @@index([operatorId])
  @@map("vehicles")
}

enum VehicleType {
  PARTICULAR
  TAXI
  MOTO
  // Vehículos de carga (empresas de transporte de mercancía / acarreos).
  TURBO   // camión mediano (NPR y similares)
  CAMION  // camión sencillo
  MULA    // tractocamión / articulado
}

// ── Negocios aliados ──────────────────────────────────────────────────────────

model Business {
  id           String           @id @default(cuid())
  name         String
  ownerName    String?
  category     BusinessCategory
  address      String
  lat          Float?
  lng          Float?
  phone        String?
  whatsapp     String?
  rating       Float            @default(5.0)
  etaMinutes   Int              @default(30)
  deliveryFee  Float            @default(2500)
  // isOpen = cuenta activa (gate de acceso al portal, lo controla el admin/registro).
  isOpen       Boolean          @default(true)
  // acceptingOrders = vitrina abierta/cerrada (pausa de pedidos que el dueño
  // controla desde el portal). Distinto de isOpen para no perder el acceso al
  // portal al cerrar. Cerrado = el negocio se ve como "Cerrado" y no toma pedidos.
  acceptingOrders Boolean       @default(true)
  // Horario de atención en texto libre (ej: "Lun-Sáb 8am-9pm"). Informativo.
  openingHours String?
  // Foto de portada del local (subida por el dueño desde el portal). Null = sin
  // portada (el cliente cae al color/ícono de la categoría).
  imageUrl     String?
  token        String           @unique @default(cuid())
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  products     Product[]
  orders       Order[]

  @@index([category])
  @@map("businesses")
}

enum BusinessCategory {
  RESTAURANT
  SUPERMARKET
  PHARMACY
  OTHER
}

model Product {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  description  String?
  price        Float
  category     String   @default("General")
  // Foto de portada (primera/principal). La galería adicional vive en `photos`.
  imageUrl     String?
  isAvailable  Boolean  @default(true)
  createdAt    DateTime @default(now())

  business     Business       @relation(fields: [businessId], references: [id])
  orderLines   OrderLine[]
  photos       ProductPhoto[]
  optionGroups OptionGroup[]

  @@index([businessId])
  @@map("products")
}

// Grupo de opciones/variantes de un producto (ej: "Tamaño", "Adiciones",
// "Quitar"). `minSelect`/`maxSelect` controlan cuántas opciones puede elegir el
// cliente (maxSelect=1 → selección única tipo radio; >1 → múltiple tipo check).
model OptionGroup {
  id         String   @id @default(cuid())
  productId  String
  name       String
  required   Boolean  @default(false)
  minSelect  Int      @default(0)
  maxSelect  Int      @default(1)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  product    Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  options    ProductOption[]

  @@index([productId])
  @@map("option_groups")
}

// Una opción dentro de un grupo (ej: "Grande" +3000, "+Queso" +2000,
// "Sin cebolla" +0). `priceDelta` se suma al precio base del producto.
model ProductOption {
  id          String   @id @default(cuid())
  groupId     String
  name        String
  priceDelta  Float    @default(0)
  isAvailable Boolean  @default(true)
  sortOrder   Int      @default(0)

  group       OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@map("product_options")
}

// Galería de fotos adicionales de un producto (además de `Product.imageUrl`).
model ProductPhoto {
  id         String   @id @default(cuid())
  productId  String
  url        String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_photos")
}

// ── Pedidos de domicilio ──────────────────────────────────────────────────────

model Order {
  id               String      @id @default(cuid())
  orderRef         String      @unique
  userId           String?
  businessId       String
  driverId         String?
  // Empresa del conductor al momento de aceptar (sellado para liquidación).
  operatorId       String?
  status           OrderStatus @default(CONFIRMED)
  deliveryAddress  String
  deliveryLat      Float?
  deliveryLng      Float?
  subtotal         Float
  deliveryFee      Float
  total            Float
  etaMinutes       Int?
  // Tiempo de preparación (min) que el restaurante fija al aceptar el pedido.
  prepMinutes      Int?
  // Momento en que el restaurante aceptó (arranca el contador de preparación).
  acceptedAt       DateTime?
  // Momento en que el restaurante marcó el pedido listo para recoger. Corre en
  // paralelo a los estados de entrega (el conductor puede ir en camino mientras
  // se cocina), por eso es timestamp y no un estado del enum.
  readyAt          DateTime?
  pickupPhotoUrl   String?
  deliveryPhotoUrl String?
  hasSignature     Boolean     @default(false)
  customerName     String?
  driverName       String?
  driverPhone      String?
  tipAmount        Float       @default(0)
  tipPaid          Boolean     @default(false)
  rating           Int?
  ratingComment    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  pickedUpAt       DateTime?
  deliveredAt      DateTime?

  user             User?       @relation(fields: [userId], references: [id])
  business         Business    @relation(fields: [businessId], references: [id])
  lines            OrderLine[]

  @@index([userId])
  @@index([driverId])
  @@index([operatorId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  DRIVER_TO_PICKUP
  AT_PICKUP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model OrderLine {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  subtotal    Float
  // Resumen legible de las opciones elegidas (ej: "Grande · +Queso · Sin cebolla").
  // El `unitPrice` ya incluye los deltas de esas opciones.
  optionsSummary String?

  order       Order   @relation(fields: [orderId], references: [id])
  product     Product @relation(fields: [productId], references: [id])

  @@map("order_lines")
}

// ── Viajes de movilidad ───────────────────────────────────────────────────────

model Trip {
  id                 String          @id @default(cuid())
  requestRef         String          @unique
  passengerId        String?
  driverId           String?
  vehicleId          String?
  serviceType        TransportType
  status             TripStatus      @default(SEARCHING)
  originAddress      String
  originLat          Float
  originLng          Float
  destAddress        String
  destLat            Float
  destLng            Float
  estimatedFare      Float
  surgeMultiplier    Float           @default(1.0)
  finalFare          Float?
  distanceKm         Float?
  etaMinutes         Int?
  cancelReason       String?
  pickupPhotoUrl     String?
  deliveryPhotoUrl   String?
  recipientName      String?
  recipientPhone     String?
  packageDescription String?
  passengerName      String?
  passengerRating    Float?
  netEarning         Float?
  commission         Float?
  tipAmount          Float           @default(0)
  tipPaid            Boolean         @default(false)
  rating             Int?
  ratingComment      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  acceptedAt         DateTime?
  startedAt          DateTime?
  arrivedAt          DateTime?
  completedAt        DateTime?

  // Empresa bajo la cual se prestó el servicio (trazabilidad legal + liquidación).
  operatorId         String?

  passenger          User?           @relation("TripPassenger", fields: [passengerId], references: [id])
  driver             Driver?         @relation(fields: [driverId], references: [id])
  vehicle            Vehicle?        @relation(fields: [vehicleId], references: [id])
  ratings            Rating[]

  @@index([passengerId])
  @@index([driverId])
  @@index([status])
  @@index([operatorId])
  @@map("trips")
}

enum TransportType {
  TAXI
  MOTO
  PARTICULAR
  ENVIOS
  MANDADO
}

enum WorkMode {
  PASAJERO
  PEDIDO
  PAQUETE
  MANDADO
}

enum TripStatus {
  SEARCHING
  ACCEPTED
  ARRIVING
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Ganancias del conductor ───────────────────────────────────────────────────

model DriverEarning {
  id          String   @id @default(cuid())
  driverId    String
  date        DateTime @db.Date
  grossFare   Float
  commission  Float
  netEarning  Float
  tripCount   Int
  createdAt   DateTime @default(now())

  driver      Driver   @relation(fields: [driverId], references: [id])

  @@unique([driverId, date])
  @@index([driverId])
  @@map("driver_earnings")
}

// ── Retiros (payouts) del conductor ───────────────────────────────────────────
//
// El conductor acumula ganancias netas en driver_earnings. Cuando solicita un
// retiro se crea un Payout en estado REQUESTED contra su saldo disponible
// (neto acumulado − retiros ya solicitados/procesando/pagados). La operación lo
// procesa desde el panel /admin y marca PAID con la referencia de la
// transferencia. La dispersión bancaria automática (Nequi/Daviplata/ACH) es un
// paso posterior; hoy el saldo y el ciclo de vida del retiro son reales.
model Payout {
  id          String       @id @default(cuid())
  driverId    String
  amount      Float
  status      PayoutStatus @default(REQUESTED)
  /// Canal de pago: 'bank' | 'nequi' | 'daviplata'.
  method      String?
  /// Snapshot del destino (banco/cuenta o teléfono) al momento de solicitar.
  accountInfo String?
  notes       String?
  /// Referencia de la transferencia, registrada por la operación al pagar.
  reference   String?
  /// Teléfono del admin que procesó el retiro.
  processedBy String?
  requestedAt DateTime     @default(now())
  processedAt DateTime?

  driver      Driver       @relation(fields: [driverId], references: [id])

  @@index([driverId])
  @@index([status])
  @@map("payouts")
}

enum PayoutStatus {
  REQUESTED
  PROCESSING
  PAID
  REJECTED
}

// ── Direcciones guardadas del usuario ─────────────────────────────────────────

model Address {
  id          String  @id @default(cuid())
  userId      String
  alias       String
  fullAddress String
  lat         Float?
  lng         Float?
  isDefault   Boolean @default(false)

  user        User    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("addresses")
}

// ── Mandados ──────────────────────────────────────────────────────────────────

model Errand {
  id               String        @id @default(cuid())
  requestRef       String        @unique
  userId           String
  driverId         String?
  // Empresa del conductor al momento de aceptar (sellado para liquidación).
  operatorId       String?
  category         ErrandCategory
  description      String
  pickupAddress    String
  dropoffAddress   String
  serviceFee       Float         @default(6000)
  purchaseBudget   Float?
  actualCost       Float?
  notes            String?
  status           ErrandStatus  @default(SEARCHING)
  proofPhotoUrl    String?
  deliveryPhotoUrl String?
  hasSignature     Boolean       @default(false)
  driverName       String?
  driverPhone      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  acceptedAt       DateTime?
  deliveredAt      DateTime?

  user             User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([driverId])
  @@index([operatorId])
  @@index([status])
  @@map("errands")
}

enum ErrandCategory {
  PHARMACY
  GROCERIES
  DOCUMENTS
  PAYMENTS
  FOOD
  SHOPPING
  OTHER
}

enum ErrandStatus {
  SEARCHING
  ACCEPTED
  SHOPPING
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

// ── Viajes Intermunicipales ────────────────────────────────────────────────────

model IntercityBooking {
  id             String          @id @default(cuid())
  requestRef     String          @unique
  userId         String
  driverId       String?
  origin         IntercityCity
  destination    IntercityCity
  departureTime  DateTime
  seats          IntercitySeats
  offeredFare    Float
  counterFare    Float?
  finalFare      Float?
  status         IntercityStatus @default(SEARCHING)
  pickupAddress  String?
  dropoffAddress String?
  notes          String?
  driverName     String?
  driverPhone    String?
  driverVehicle  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  confirmedAt    DateTime?
  completedAt    DateTime?
  rating         Int?
  ratingComment  String?

  // Empresa bajo la cual se prestó el servicio (troncales legales + liquidación).
  operatorId     String?

  user           User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([operatorId])
  @@map("intercity_bookings")
}

enum IntercityCity {
  PAMPLONA
  CUCUTA
  BUCARAMANGA
  CHITAGA
  MALAGA
  OCANA
  BOGOTA
}

enum IntercitySeats {
  ONE
  TWO
  THREE
  FLEET
}

enum IntercityStatus {
  SEARCHING
  DRIVER_FOUND
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Viajes compartidos (Modelo A) ─────────────────────────────────────────────

model PooledTrip {
  id                 String           @id @default(cuid())
  tripRef            String           @unique
  driverId           String
  driverName         String
  driverPhone        String
  vehicleDescription String
  origin             IntercityCity
  destination        IntercityCity
  departureTime      DateTime
  totalSeats         Int
  farePerSeat        Float
  maxFarePerSeat     Float
  allowFleet         Boolean          @default(false)
  status             PooledTripStatus @default(OPEN)
  notes              String?
  // Empresa que publicó la salida (null = conductor particular). Sin FK,
  // mismo patrón que IntercityBooking.operatorId.
  operatorId         String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  bookings           SeatBooking[]

  @@index([driverId])
  @@index([status])
  @@index([origin, destination])
  @@index([operatorId])
  @@map("pooled_trips")
}

model SeatBooking {
  id             String            @id @default(cuid())
  tripId         String
  userId         String
  passengerName  String
  passengerPhone String
  seatsBooked    Int
  pickupAddress  String?
  notes          String?
  status         SeatBookingStatus @default(CONFIRMED)
  bookedAt       DateTime          @default(now())

  trip          PooledTrip        @relation(fields: [tripId], references: [id])
  user          User              @relation(fields: [userId], references: [id])

  @@index([tripId])
  @@index([userId])
  @@map("seat_bookings")
}

enum PooledTripStatus {
  OPEN
  FULL
  DEPARTED
  COMPLETED
  CANCELLED
}

enum SeatBookingStatus {
  CONFIRMED
  CANCELLED
}

// ── Calificaciones ────────────────────────────────────────────────────────────

model Rating {
  id        String   @id @default(cuid())
  authorId  String
  tripId    String?
  stars     Int
  comment   String?
  createdAt DateTime @default(now())

  author    User     @relation("RatingAuthor", fields: [authorId], references: [id])
  trip      Trip?    @relation(fields: [tripId], references: [id])

  @@map("ratings")
}

// ── Pagos (Wompi) ─────────────────────────────────────────────────────────────

model Payment {
  id            String   @id @default(cuid())
  referenceCode String   @unique
  amount        Float
  currency      String   @default("COP")
  description   String
  clientId      String
  orderId       String?
  tripId        String?
  status        String   @default("pending")
  paymentUrl    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clientId])
  @@map("payments")
}

// ── Eventos de emergencia (SOS / compartir viaje) ─────────────────────────────

model EmergencyEvent {
  id        String        @id @default(cuid())
  userId    String?
  driverId  String?
  tripId    String?
  lat       Float
  lng       Float
  type      EmergencyType @default(PANIC)
  createdAt DateTime      @default(now())

  user      User?    @relation(fields: [userId], references: [id])
  driver    Driver?  @relation(fields: [driverId], references: [id])

  @@index([userId])
  @@index([driverId])
  @@index([tripId])
  @@map("emergency_events")
}

enum EmergencyType {
  PANIC // botón de pánico pulsado
  SHARE // viaje compartido con contacto de confianza
}

// ── Empresas de transporte (operadores) + flota ───────────────────────────────
//
// Una Operator es una empresa de taxi o de transporte intermunicipal habilitada.
// De ella cuelgan su flota (Vehicle.operatorId), sus conductores afiliados
// (Driver.operatorId), sus documentos legales, los usuarios de su portal y las
// rutas que está autorizada a operar. Cada viaje se sella con operatorId para
// trazabilidad legal y liquidación. Ver docs/ESTRUCTURA_EMPRESAS_FLOTAS.md.

model Operator {
  id                    String         @id @default(cuid())
  legalName             String
  nit                   String         @unique
  tradeName             String?
  // EMPRESA = persona jurídica (razón social + NIT); PERSONA = dueño natural
  // de varios vehículos (nombre completo + cédula en los mismos campos).
  kind                  OperatorKind   @default(EMPRESA)
  type                  OperatorType
  status                OperatorStatus @default(PENDING)
  isVerified            Boolean        @default(false)
  habilitacionNo        String? // número de resolución de habilitación (Mintransporte)
  habilitacionExpiresAt DateTime?
  contactName           String?
  contactPhone          String?
  contactEmail          String?
  city                  String?
  commissionRate        Float? // override de comisión de plataforma (null = global)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  documents   OperatorDocument[]
  members     OperatorMember[]
  routes      OperatorRoute[]
  vehicles    Vehicle[]
  drivers     Driver[]
  assignments FleetAssignment[]

  @@map("operators")
}

model OperatorDocument {
  id              String          @id @default(cuid())
  operatorId      String
  type            OperatorDocType
  fileUrl         String
  status          DocumentStatus  @default(PENDING)
  expiresAt       DateTime?
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?
  uploadedAt      DateTime        @default(now())

  operator        Operator        @relation(fields: [operatorId], references: [id])

  @@index([operatorId])
  @@index([status])
  @@map("operator_documents")
}

model OperatorMember {
  id         String       @id @default(cuid())
  operatorId String
  phone      String // login OTP al portal de empresa
  name       String?
  role       OperatorRole @default(VIEWER)
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())

  operator   Operator     @relation(fields: [operatorId], references: [id])

  @@unique([operatorId, phone])
  @@index([operatorId])
  @@map("operator_members")
}

model OperatorRoute {
  id         String   @id @default(cuid())
  operatorId String
  originCity String
  destCity   String
  authorized Boolean  @default(false)
  createdAt  DateTime @default(now())

  operator   Operator @relation(fields: [operatorId], references: [id])

  @@unique([operatorId, originCity, destCity])
  @@index([operatorId])
  @@map("operator_routes")
}

model FleetAssignment {
  id         String    @id @default(cuid())
  operatorId String
  driverId   String
  vehicleId  String
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  active     Boolean   @default(true)

  operator   Operator  @relation(fields: [operatorId], references: [id])
  driver     Driver    @relation(fields: [driverId], references: [id])
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id])

  @@index([operatorId])
  @@index([driverId])
  @@index([vehicleId])
  @@map("fleet_assignments")
}

enum OperatorKind {
  EMPRESA // persona jurídica
  PERSONA // dueño natural de vehículos (2-3 camiones/turbos propios)
}

enum OperatorType {
  TAXI
  INTERCITY
  MIXED
  CARGA // empresa de transporte de carga (mulas, turbos, camiones)
}

enum OperatorStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum OperatorDocType {
  HABILITACION
  RUT
  CAMARA_COMERCIO
  INSURANCE
  OTHER
}

enum OperatorRole {
  OWNER
  DISPATCHER
  VIEWER
}

enum EmploymentType {
  OWN
  AFFILIATED
}

// ── Fletes de carga (cliente ↔ empresa/dueño de camiones) ─────────────────────

enum FreightStatus {
  REQUESTED   // publicado por el cliente, visible para las flotas de carga
  ACCEPTED    // una empresa/dueño lo tomó (conductor + vehículo asignados)
  IN_PROGRESS // carga en ruta
  COMPLETED   // entregado y liquidado (comisión de plataforma descontada)
  CANCELLED
}

model FreightRequest {
  id               String        @id @default(cuid())
  clientId         String
  clientName       String?
  clientPhone      String?
  originAddress    String
  destAddress      String
  // Ciudades (texto libre): iguales u omitidas = acarreo urbano; distintas =
  // flete intermunicipal. La fecha futura lo vuelve "programado".
  originCity       String?
  destCity         String?
  cargoDescription String
  weightKg         Int
  vehicleType      VehicleType   // TURBO | CAMION | MULA
  offeredPrice     Float
  scheduledFor     DateTime?     // null = lo antes posible
  status           FreightStatus @default(REQUESTED)
  operatorId       String?
  driverId         String?
  vehicleId        String?
  finalPrice       Float?
  commission       Float?
  netEarning       Float?
  // Coordenadas de la trayectoria (para dibujar el mapa del flete). Se
  // resuelven al crear el flete desde el centroide de la ciudad (fallback
  // Pamplona); permiten mostrar origen→destino en la app del conductor.
  originLat        Float?
  originLng        Float?
  destLat          Float?
  destLng          Float?
  createdAt        DateTime      @default(now())
  acceptedAt       DateTime?
  completedAt      DateTime?

  @@index([status])
  @@index([operatorId])
  @@index([clientId])
  @@map("freight_requests")
}

// ─── Chat de viaje (pasajero ↔ conductor) ──────────────────────────────────────
// Mensajería persistente atada a un Trip. senderRole: 'client' | 'driver'.
model TripMessage {
  id        String   @id @default(cuid())
  tripId    String
  senderRole String  // 'client' | 'driver'
  senderId  String
  body      String   @default("")
  imageUrl  String?  // mensaje con foto (compartir ubicación/estado). null = texto
  createdAt DateTime @default(now())

  @@index([tripId])
  @@map("trip_messages")
}

// ─── Soporte con tickets ────────────────────────────────────────────────────────
enum SupportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model SupportTicket {
  id            String          @id @default(cuid())
  // Quién abre el ticket: 'client' | 'driver'.
  requesterKind String
  requesterId   String
  requesterName String?
  subject       String
  category      String          @default("general")
  status        SupportStatus   @default(OPEN)
  messages      SupportMessage[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([requesterKind, requesterId])
  @@index([status])
  @@map("support_tickets")
}

model SupportMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  // Autor: 'client' | 'driver' | 'admin'.
  authorKind String
  authorId   String?
  body       String
  createdAt  DateTime      @default(now())

  @@index([ticketId])
  @@map("support_messages")
}

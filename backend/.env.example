# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # production on Railway/Render

# Verbosidad del logger: debug | info | warn | error
# (por defecto: debug en desarrollo, info en producción)
LOG_LEVEL=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# ── CORS ─────────────────────────────────────────────────────────────────────
# Mobile apps send no Origin header, so * is safe for the API.
# Restrict to your web portal domain once you have one.
CORS_ORIGIN=*

# ── SMS OTP (Twilio Verify) ───────────────────────────────────────────────────
# Leave blank to stay in mock-OTP mode (always accepts "123456").
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# ── Database (OBLIGATORIO) ────────────────────────────────────────────────────
# El backend usa Prisma + PostgreSQL. El contenedor corre `prisma migrate
# deploy` al arrancar (entrypoint.sh), así que esta variable DEBE estar
# definida o el arranque falla.
DATABASE_URL=postgresql://user:pass@host:5432/nexum_db

# ── Google Maps (servidor) ────────────────────────────────────────────────────
# Clave para Directions/Geocoding/Places desde el backend. Si está vacía, las
# rutas caen a una línea recta de respaldo. Usa una clave distinta a la de las
# apps y restríngela por IP del servidor.
GOOGLE_MAPS_API_KEY=

# ── Push notifications (Firebase Cloud Messaging) ─────────────────────────────
# JSON (en una sola línea) del service account de Firebase. Si está vacío, el
# push queda desactivado (no-op) y nada se rompe.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Portal web (links en notificaciones / negocios) ───────────────────────────
PORTAL_BASE_URL=https://nexum.app

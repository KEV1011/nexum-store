# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # production on Railway/Render

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# ── CORS ─────────────────────────────────────────────────────────────────────
# Mobile apps send no Origin header, so * is safe for the API.
# Restrict to your web portal domain once you have one.
CORS_ORIGIN=*

# ── SMS OTP (Twilio Verify) ───────────────────────────────────────────────────
# Con las tres definidas, el OTP se envía por SMS real (Twilio genera y valida
# el código). Crear en https://console.twilio.com → Verify → Services.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
# Sin Twilio: en desarrollo el código fijo es OTP_DEV_CODE (default 123456).
# En producción sin Twilio el login queda cerrado salvo que definas
# OTP_FALLBACK_CODE (solo para pilotos controlados — todos usan ese código).
OTP_DEV_CODE=123456
OTP_FALLBACK_CODE=

# ── Pagos (Wompi) ─────────────────────────────────────────────────────────────
# Llaves en https://comercios.wompi.co → Desarrolladores. Usa pub_test_/prv_test_
# para sandbox; al pasar a producción cambia a pub_prod_/prv_prod_.
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
# "Secreto de eventos" — valida la firma de los webhooks (X-Event-Checksum).
WOMPI_EVENTS_SECRET=
# "Secreto de integridad" — firma los links de checkout (obligatorio si la
# cuenta tiene firma de integridad activada).
WOMPI_INTEGRITY_SECRET=
# URL pública del backend; Wompi redirige al usuario a APP_URL/payment/result.
APP_URL=http://localhost:3000

# ── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
# Required. Use the docker-compose postgres service locally:
DATABASE_URL=postgresql://nexum:nexum_dev_secret@localhost:5432/nexum_db

# ── Admin panel (driver verification) ────────────────────────────────────────
# Comma-separated phone numbers allowed into /admin. Empty = panel disabled.
ADMIN_PHONES=

# ── Intercity (gasto compartido) ─────────────────────────────────────────────
# See INTERCITY_LEGAL_NOTES.md. Defaults = Option A (cost-share cap enforced).
# TODO: confirmar las cifras reales 2026 con el operador antes de producción.
SHARED_RIDE_COST_PER_KM=950
SHARED_RIDE_TOLL_PER_100KM=16000
# Option B — block trunk routes for particular drivers (requires licensed operator):
INTERCITY_DUAL_MODEL=false
# Option C — remove the cost-share cap (only with legal habilitación, shows disclaimer):
INTERCITY_REMOVE_CAP=false
# Demo only: simulate intercity driver responses instead of real matching
INTERCITY_SIMULATE=false

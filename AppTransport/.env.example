# Google Maps API Key
# Obtén tu key en: https://console.cloud.google.com/
# Habilitar APIs: Maps SDK for Android, Maps SDK for iOS
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Entorno de la aplicación
APP_ENV=development

# URL base del API (cuando exista backend real)
API_BASE_URL=https://api.nexum.co/v1
